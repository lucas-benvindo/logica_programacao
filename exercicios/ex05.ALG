Algoritmo "ex05"
// Disciplina   : [Linguagem e Lógica de Programaçăo]
// Professor   : Antonio Carlos Nicolodi 
// Descriçăo   : Aqui vocę descreve o que o programa faz! (funçăo)
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 06/04/2026
Var
// Seçăo de Declaraçőes das variáveis 
   in, fim, c: inteiro

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
   Escreval("----------------------") //TÍTULO PRINCIPAL
   Escreval(" CONTAGEM INTELIGENTE ")
   Escreval("----------------------")
   
   Escreva("ÍNICIO: ") //INFORMAÇĂO DO INÍCIO E FIM (NÚMEROS)
   Leia(in)
   Escreva("FIM: ")
   Leia(fim)
   
   Escreval("----------------------") //TÍTULO CONTAGEM
   Escreval("   C O N T A N D O   ")
   Escreval("----------------------")
   
   c <- in
   
   Se(in < fim) entao
      Enquanto (c <= fim) faca
         Escreva(c)
         c <- c + 1
      FimEnquanto
   senao
      Enquanto (c >= fim) faca
      Escreva(c)
      c <- c - 1
      FimEnquanto
   FimSe

Fimalgoritmo
