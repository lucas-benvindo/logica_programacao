Algoritmo "ex04"
// Disciplina   : [Linguagem e Lógica de Programaçăo]
// Professor   : Antonio Carlos Nicolodi 
// Descriçăo   : Aqui vocę descreve o que o programa faz! (funçăo)
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 06/04/2026
Var
// Seçăo de Declaraçőes das variáveis 
   bng, mdr, dif: inteiro

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
   Escreval("-------------------") //TÍTULO
   Escreval(" BANGU X MADUREIRA ")
   Escreval("-------------------")
   
   Escreva("Quantos gols do BANGU? ") //INFORMAÇĂO DOS GOLS
   Leia(bng)
   Escreva("Quantos gols do MADUREIRA? ")
   Leia(mdr)
   Escreval("-------------------")
   
   dif <- abs(bng - mdr) //DIFERENÇA
   Escreval("DIFERENÇA:", dif)
   
   Escolha dif //STATUS
      Caso 0
        Escreval("STATUS: EMPATE")
        
      Caso 1,2,3
        Escreval("STATUS: PARTIDA NORMAL")
        
      OutroCaso
        Escreval("STATUS: GOLEADA")
   FimEscolha
   Escreval("-------------------")
   
Fimalgoritmo